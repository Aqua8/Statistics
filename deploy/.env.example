# 도메인 (DNS A레코드가 VM IP를 가리켜야 함)
STATS_DOMAIN=stats.yourdomain.com
PORTFOLIO_DOMAIN=yourdomain.com
MATJIP_DOMAIN=matjip.yourdomain.com
CERTBOT_EMAIL=your@email.com

# 데이터베이스 (Statistics)
DB_ROOT_PASSWORD=your_root_password
DB_NAME=dashboard_db
DB_USERNAME=your_db_user
DB_PASSWORD=your_db_password

# 앱 (Statistics)
JWT_SECRET=your_jwt_secret_base64
ALLOWED_ORIGINS=https://stats.yourdomain.com
GUEST_USER_ID=1
GUEST_PROJECT_ID=1

# MatJip (맛집 리뷰 서비스)
MATJIP_DB_ROOT_PASSWORD=your_matjip_root_password
MATJIP_DB_NAME=matjip
MATJIP_DB_USERNAME=your_matjip_db_user
MATJIP_DB_PASSWORD=your_matjip_db_password
MATJIP_JWT_SECRET=your_matjip_jwt_secret_base64
# GCS 버킷명 (VM 서비스 계정에 해당 버킷 권한 필요 — 키 파일 없이 ADC 사용)
MATJIP_GCS_BUCKET=your-gcs-bucket-name
